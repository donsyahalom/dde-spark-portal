# .env.sync.example
# Copy this to .env.sync and fill in your real values.
# NEVER commit .env.sync to git — it contains service_role keys.
#
# Usage:
#   node --env-file=.env.sync scripts/sync-prod-to-uat.js

# ── Production Supabase ────────────────────────────────────────────────────────
PROD_SUPABASE_URL=https://YOUR-PROD-PROJECT-ID.supabase.co
PROD_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PROD_SERVICE_ROLE_KEY_HERE

# ── UAT Supabase ──────────────────────────────────────────────────────────────
UAT_SUPABASE_URL=https://YOUR-UAT-PROJECT-ID.supabase.co
UAT_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.UAT_SERVICE_ROLE_KEY_HERE
